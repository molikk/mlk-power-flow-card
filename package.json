  "bugs": {
    "url": "https://github.com/molikk/mlk-power-flow-card/issues"
  },
  "homepage": "https://github.com/molikk/mlk-power-flow-card#readme",
  "dependencies": {
    "@lit-labs/scoped-registry-mixin": "^1.0.4",
    "custom-card-helpers": "^2.0.0",
    "lit": "^3.3.1",
    "lodash.merge": "^4.6.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@babel/plugin-transform-template-literals": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^9.33.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-eslint": "^9.2.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/lodash.merge": "^4.6.9",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "babel-preset-minify": "^0.5.2",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "17.6.0",
    "npm": "11.16.0",
    "prettier": "3.8.3",
